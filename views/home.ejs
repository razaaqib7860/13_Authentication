<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>home page</title>

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body{
            background:#f5f7fa;
            display:flex;
            justify-content:center;
            align-items:center;
            height:100vh;
        }

        .container{
            width:500px;
            background:#fff;
            padding:40px;
            border-radius:15px;
            box-shadow:0 10px 25px rgba(0,0,0,.12);
        }

        h1{
            text-align:center;
            margin-bottom:35px;
            color:#222;
        }

        label{
            display:block;
            font-weight:600;
            margin-bottom:10px;
        }

        input{
            width:100%;
            padding:14px;
            font-size:16px;
            border:1px solid #ccc;
            border-radius:8px;
            outline:none;
            margin-bottom:20px;
        }

        input:focus{
            border-color:#007bff;
        }

        button{
            width:100%;
            padding:14px;
            border:none;
            border-radius:8px;
            background:#007bff;
            color:white;
            font-size:16px;
            cursor:pointer;
            transition:.3s;
        }

        button:hover{
            background:#0056d2;
        }

    </style>
</head>

<body>

<div class="container">

    <h1>URL Shortener</h1>

    <form action="/url" method="POST">

        <label>Paste the URL to be Shortened:</label>

        <input
            type="text"
            name="originalUrl"
            placeholder="https://www.example.com"
            required
        >

        <button type="submit">
            Generate
        </button>

    </form>

</div>

</body>
</html>