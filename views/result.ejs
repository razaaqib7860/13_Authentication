<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Short URL Generated</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
        }

        body {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: linear-gradient(135deg, #eef2f7 0%, #dfe6ed 100%);
            padding: 20px;
        }

        .card {
            width: 100%;
            max-width: 550px;
            background: white;
            padding: 40px 30px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            text-align: center;
        }

        /* Success Checkmark Header */
        .success-icon {
            width: 60px;
            height: 60px;
            background: #e6f9f0;
            color: #10b981;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 0 auto 20px auto;
        }

        .success-icon svg {
            width: 30px;
            height: 30px;
        }

        h1 {
            font-size: 28px;
            color: #1e293b;
            margin-bottom: 8px;
            font-weight: 700;
        }

        .subtitle {
            color: #64748b;
            font-size: 15px;
            margin-bottom: 30px;
        }

        /* Group Containers */
        .url-section-box {
            border-radius: 12px;
            padding: 20px;
            text-align: left;
            margin-bottom: 20px;
            position: relative;
        }

        .original-box {
            background-color: #f0f7ff;
            border: 1px solid #e0f0ff;
        }

        .short-box {
            background-color: #f4fbf7;
            border: 1px solid #e1f7ec;
        }

        .section-title-wrapper {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 12px;
        }

        .section-icon {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .original-box .section-icon { background: #dbeafe; color: #2563eb; }
        .short-box .section-icon { background: #d1fae5; color: #059669; }

        .section-title {
            font-size: 15px;
            font-weight: 600;
        }

        .original-box .section-title { color: #1e40af; }
        .short-box .section-title { color: #065f46; }

        /* Links & Text Wrapping */
        .original-url-display {
            display: block;
            color: #2563eb;
            text-decoration: none;
            font-size: 14px;
            line-height: 1.5;
            word-break: break-all;
            padding-right: 30px;
        }

        .original-url-display:hover {
            text-decoration: underline;
        }

        .external-link-icon {
            position: absolute;
            right: 20px;
            bottom: 20px;
            color: #2563eb;
        }

        /* Interactive Short URL Row */
        .input-group {
            display: flex;
            gap: 10px;
            margin-top: 10px;
        }

        .input-group input {
            flex: 1;
            padding: 12px 16px;
            border: 1px solid #cbd5e1;
            border-radius: 8px;
            font-size: 14px;
            color: #334155;
            background: white;
            outline: none;
        }

        .copy-btn {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 12px 20px;
            background: #10b981;
            color: white;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: background 0.2s;
        }

        .copy-btn:hover {
            background: #059669;
        }

        /* Action Buttons Grid */
        .btn-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-bottom: 25px;
        }

        .action-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 14px;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s;
        }

        .btn-outline {
            border: 1px solid #2563eb;
            color: #2563eb;
            background: transparent;
        }

        .btn-outline:hover {
            background: #f0f7ff;
        }

        .btn-primary {
            background: #10b981;
            color: white;
        }

        .btn-primary:hover {
            background: #059669;
        }

        /* Footer Info Box */
        .footer-banner {
            background: #f8fafc;
            border: 1px solid #f1f5f9;
            border-radius: 12px;
            padding: 16px;
            display: flex;
            align-items: center;
            gap: 15px;
            text-align: left;
        }

        .footer-icon {
            width: 36px;
            height: 36px;
            background: #e2e8f0;
            color: #475569;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            flex-shrink: 0;
        }

        .footer-text h4 {
            font-size: 14px;
            color: #334155;
            margin-bottom: 2px;
        }

        .footer-text p {
            font-size: 12px;
            color: #64748b;
        }
    </style>
</head>
<body>

<div class="card">
    <div class="success-icon">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path>
        </svg>
    </div>

    <h1>Short URL Generated</h1>
    <p class="subtitle">Your link is ready to use and share</p>

    <div class="url-section-box original-box">
        <div class="section-title-wrapper">
            <div class="section-icon">
                <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.143m0-4.243L14.707 9.707a4 4 0 015.656 0l4 4a4 4 0 11-5.656 5.656"></path>
                </svg>
            </div>
            <span class="section-title">Original URL</span>
        </div>
        <a href="<%= originalUrl %>" target="_blank" class="original-url-display">
            <%= originalUrl %>
        </a>
        <a href="<%= originalUrl %>" target="_blank" class="external-link-icon">
            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
            </svg>
        </a>
    </div>

    <div class="url-section-box short-box">
        <div class="section-title-wrapper">
            <div class="section-icon">
                <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.143m0-4.243L14.707 9.707a4 4 0 015.656 0l4 4a4 4 0 11-5.656 5.656"></path>
                </svg>
            </div>
            <span class="section-title">Your Short URL</span>
        </div>
        
        <div class="input-group">
            <input id="shortUrl" type="text" readonly value="<%= locals.baseUrl %>/url/<%= locals.SUrl %>">
            <button onclick="copyURL()" class="copy-btn">
                <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"></path>
                </svg>
                Copy
            </button>
        </div>
    </div>

    <div class="btn-grid">
        <a href="/UrlShortner/track/<%= locals.SUrl %>" class="action-btn btn-outline">
            View Analytics &gt;
        </a>
        <a href="/UrlShortner" class="action-btn btn-primary">
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="margin-right: 4px;">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.253 8H18"></path>
            </svg>
            Generate Another
        </a>
    </div>

    <div class="footer-banner">
        <div class="footer-icon">
            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
        </div>
        <div class="footer-text">
            <h4>Share your short link anywhere!</h4>
            <p>It's fast, reliable, and always available.</p>
        </div>
    </div>
</div>

<script>
function copyURL(){
    const input = document.getElementById("shortUrl");
    input.select();
    input.setSelectionRange(0, 99999); /* For mobile devices */
    navigator.clipboard.writeText(input.value);
    
    // Quick interactive UI response for copy button
    const btn = document.querySelector('.copy-btn');
    const originalText = btn.innerHTML;
    btn.style.background = '#047857';
    btn.innerText = '✓ Copied!';
    setTimeout(() => {
        btn.style.background = '#10b981';
        btn.innerHTML = originalText;
    }, 2000);
}
</script>

</body>
</html>
