<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>URL Analytics</title>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #eef2f7 0%, #dfe6ed 100%);
            padding: 40px 20px;
            display: flex;
            justify-content: center;
            align-items: flex-start;
        }

        .container {
            width: 100%;
            max-width: 1000px;
            background: white;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        }

        h1 {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 28px;
            color: #1e293b;
            margin-bottom: 35px;
            font-weight: 700;
        }

        /* Metrics Display Grid */
        .cards {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 35px;
        }

        .card {
            background: #f8fafc;
            border: 1px solid #f1f5f9;
            padding: 24px;
            border-radius: 16px;
            text-align: center;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .card:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.03);
        }

        .card h3 {
            color: #64748b;
            font-size: 14px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 12px;
        }

        .card h2 {
            color: #2563eb;
            font-size: 48px;
            font-weight: 700;
            line-height: 1.1;
        }

        /* Specific styles for special cards */
        .card.today h2 {
            color: #0ea5e9;
        }

        .card.last h2.last-click {
            color: #64748b;
            font-size: 16px;
            font-weight: 600;
            line-height: 1.5;
        }

        .card.last h2.no-clicks {
            color: #94a3b8;
            font-size: 22px;
            font-weight: 600;
        }

        /* Content Sections */
        .info {
            background: white;
            border: 1px solid #e2e8f0;
            padding: 30px;
            border-radius: 16px;
            margin-bottom: 30px;
        }

        .info h3 {
            font-size: 18px;
            color: #1e293b;
            margin-bottom: 24px;
            font-weight: 600;
        }

        .url-group {
            margin-bottom: 20px;
        }

        .url-group:last-child {
            margin-bottom: 0;
        }

        .url-group label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: #475569;
            margin-bottom: 8px;
        }

        .url {
            background: #f1f5f9;
            padding: 14px 18px;
            border-radius: 10px;
            color: #334155;
            font-size: 14px;
            line-height: 1.5;
            word-break: break-all;
            border: 1px solid #e2e8f0;
        }

        /* Navigation Buttons */
        .back-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 14px 24px;
            background: #10b981;
            color: white;
            text-decoration: none;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 600;
            transition: background 0.2s;
        }

        .back-btn:hover {
            background: #059669;
        }

        @media (max-width: 768px) {
            .cards {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>

<div class="container">

    <h1>
        <svg width="28" height="28" fill="none" stroke="#2563eb" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 002 2h2a2 2 0 002-2z"></path>
        </svg>
        URL Analytics
    </h1>

    <div class="cards">
        <div class="card">
            <h3>Total Clicks</h3>
            <h2><%= url.clicks %></h2>
        </div>

        <div class="card today">
            <h3>Today's Clicks</h3>
            <h2><%= url.clicks %></h2>
        </div>

        <div class="card last">
            <h3>Last Click</h3>
